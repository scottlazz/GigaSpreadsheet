{
  "name": "gigasheet",
  "private": false,
  "version": "0.0.1",
  "source": "src/index.html",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "main": "dist/indexejs.js",
  "scripts": {
    "start": "parcel --no-cache",
    "start:golden": "parcel src/golden.html",
    "clean": "rimraf dist",
    "copyfiles": "node ./copyfiles.js",
    "build": "npm run build:ts && npm run copyfiles",
    "build:ts": "npm run clean && tsc -p tsconfig.json",
    "dev": "npm run copyfiles && tsc -p tsconfig.json --watch",
    "build:lib": "npm run build:ts",
    "prepare": "npm run build:ts",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest tests/sheet-integration.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text-summary"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "gh-pages": "^6.3.0",
    "golden-layout": "^2.6.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "parcel": "^2.16.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  }
}
